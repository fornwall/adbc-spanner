// Spanner override: Spanner TIMESTAMP is timezone-aware (absolute instant in UTC),
// mapped to Arrow Timestamp(Nanosecond, "UTC"). The literal value (2023-05-15) is
// inside Arrow's nanosecond range, so port it with an explicit UTC offset.

// part: query

SELECT TIMESTAMP '2023-05-15 13:45:30+00' AS res

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "res",
            "format": "tsn:UTC",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"res": 1684158330000000000}
