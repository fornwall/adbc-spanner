// Spanner override: FLOAT32 cannot be a primary key, so add a synthetic UUID key
// (defaulted, so the bind INSERT only supplies res) and keep res a plain column.

// part: setup_query

CREATE TABLE test_float32 (
    res FLOAT32,
    pk STRING(36) DEFAULT (GENERATE_UUID())
) PRIMARY KEY (pk)

// part: bind_query

INSERT INTO test_float32 (res) VALUES ($1)
